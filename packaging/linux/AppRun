#!/bin/bash
# AppRun entry point used by the AppImage runtime.
#
# The PyInstaller one-file binary is fully self-contained: it extracts
# its embedded Python interpreter, Qt libraries and data files into a
# temporary directory at startup, so we just need to exec it.
HERE="$(dirname "$(readlink -f "${0}")")"
exec "${HERE}/usr/bin/EditableTreeModel" "$@"
